# Myna — Communication Style Configuration
# Copy to: _system/config/communication-style.yaml
#
# Controls how Myna drafts emails, messages, and other written content.
# Start with a preset and customize per audience tier as needed.
# Falls back to role-based defaults when not present.

# Available presets:
#   assertive   — direct, clear ask, no hedging
#   analytical  — evidence-first, structured reasoning
#   empathetic  — relationship-first, acknowledges context
#   formal      — polished, structured, safe for any audience
#   executive   — BLUF, outcome-focused, so-what first
default_preset: assertive

# Override the preset for specific audience tiers
presets_per_tier:
  upward: executive                     # Messages to your manager, VP, execs
  peer: assertive                       # Messages to peers and other managers
  direct: empathetic                    # Messages to direct reports
  cross-team: formal                    # Messages to other teams

# Email formatting
sign_off: "Best"                        # Email sign-off (e.g., Best, Thanks, Cheers)

# Advanced preferences
email_preferences:
  greeting_style: first-name            # first-name | formal | none
