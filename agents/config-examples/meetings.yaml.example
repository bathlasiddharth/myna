# Myna — Meetings Configuration
# Copy to: _system/config/meetings.yaml
#
# Optional overrides. Most meetings need no entry here — Myna infers the type
# from calendar data (attendees, recurrence, title patterns). Only add meetings
# that need custom type assignment or special processing.

meetings:
  - name: Weekly Architecture Review    # Meeting name as it appears in your calendar
    aliases: [arch review, WAR]         # Short names for quick reference
    type: recurring                     # 1-1 | recurring | adhoc | project
    project: Platform API               # Associate with a project (for prep and processing)
    debrief_type: design-review         # Customize processing emphasis:
                                        #   design-review | standup | project | general

  - name: Sprint Standup
    aliases: [standup, daily standup]
    type: recurring
    debrief_type: standup
